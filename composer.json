{
    "name": "saakiiib/laravel-spa",
    "description": "Zero-reload SPA engine for Laravel Blade — no jQuery, no Livewire, no Inertia.",
    "type": "library",
    "license": "MIT",
    "authors": [{ "name": "Sakib", "role": "Developer" }],
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0"
    },
    "autoload": {
        "psr-4": {
            "Sakib\\LaravelSpa\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "extra": {
        "laravel": {
            "providers": ["Sakib\\LaravelSpa\\SpaServiceProvider"]
        }
    },
    "minimum-stability": "stable"
}